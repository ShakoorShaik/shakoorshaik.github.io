---
import Layout from '../layouts/Layout.astro'
import HeroTerminal from '../components/HeroTerminal'
import Projects from '../components/Projects'
import { personal, techStack, tools } from '../data/portfolio'
---

<Layout>
  <div class="min-h-screen text-[var(--color-foreground)]">
    <!-- Noise texture overlay -->
    <div
      class="fixed inset-0 pointer-events-none z-0 opacity-[0.025]"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px;"
    ></div>

    <!-- Sticky nav -->
    <header class="fixed top-0 inset-x-0 z-50 border-b border-[#161616] bg-[#0a0a0a]/85 backdrop-blur-md">
      <div class="w-full max-w-[1600px] mx-auto px-5 sm:px-8 md:px-10 xl:px-14 2xl:px-16 grid grid-cols-[1fr_auto_1fr] items-center" style="height:52px;">
        <!-- Left spacer to keep center nav alignment -->
        <div aria-hidden="true"></div>
        <!-- Center: nav links -->
        <nav class="flex items-center gap-0.5">
          <a href="#projects" class="text-[13px] px-3 py-1.5 rounded-md text-[var(--color-foreground)] bg-[#151515] transition-all duration-150">Projects</a>
          <a href="#stack" class="text-[13px] px-3 py-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[#111] transition-all duration-150">Tech Stack</a>
          <a href="#tools" class="text-[13px] px-3 py-1.5 rounded-md text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[#111] transition-all duration-150">Tools</a>
        </nav>
        <!-- Right: icon buttons -->
        <div class="flex items-center gap-1 justify-end">
          <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="flex items-center justify-center w-8 h-8 rounded-md text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[#111] transition-all duration-150">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href={personal.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="flex items-center justify-center w-8 h-8 rounded-md text-[var(--color-muted)] hover:text-[var(--color-foreground)] hover:bg-[#111] transition-all duration-150">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </header>

    <main class="relative z-10 w-full max-w-[1600px] mx-auto px-5 sm:px-8 md:px-10 xl:px-14 2xl:px-16 pb-24 pt-[52px]">

      <!-- ═══════════════════════════════════════════
           HERO — bio left, terminal right
      ════════════════════════════════════════════ -->
      <section class="pt-12 md:pt-14 mb-24 md:mb-28 animate-fade-up delay-1">
        <!-- Availability badge -->
        <div class="mb-8 md:mb-10">
          <span class="inline-flex items-center gap-2.5 text-[13px] md:text-[14px] text-[#888] border-2 border-[#242424] rounded-full px-4 py-2 bg-[#0f0f0f] font-medium">
            <span class="relative flex h-1.5 w-1.5 shrink-0">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4ade80] opacity-60"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-[#4ade80]"></span>
            </span>
            Open to internships &middot; Summer/Fall 2026
          </span>
        </div>

        <div class="flex flex-col md:flex-row md:items-center gap-12 md:gap-14 xl:gap-[4.5rem]">

          <!-- Left: display headline + blurb -->
          <div class="flex-1 min-w-0 md:py-1">
            <h1 class="text-[clamp(2.625rem,3.2vw+1.75rem,3.875rem)] sm:text-[3.375rem] lg:text-[3.625rem] xl:text-[4rem] font-bold leading-[1.06] tracking-[-0.02em] mb-6 md:mb-8">
              <span class="text-[#505050]">Hey! I'm </span><span class="text-white">{personal.name}</span><span class="text-[#505050]">,<br/>a </span><span class="text-white">Software<br/>Developer</span><span class="text-[#505050]"><br/>and </span><span class="text-white">ML Engineer</span><span class="text-[#505050]">.</span>
            </h1>

            <p class="text-[17px] md:text-[18px] xl:text-[19px] text-[#707070] leading-[1.7] mb-8 md:mb-10 max-w-[36rem] xl:max-w-[40rem]">
              I build web apps, mobile apps, software solutions, and data-driven systems. CS student at
              <span class="text-[#9a9a9a]">UofT</span> — Dean's List 2025.<br /><br /> Reach me at
              <a href={`mailto:${personal.email}`} class="text-[#939393] underline underline-offset-4 hover:text-white transition-colors duration-150">{personal.email}</a>.
            </p>

            <!-- Social icon buttons -->
            <div class="flex flex-wrap gap-3">
              <!-- GitHub -->
              <a
                href={personal.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub"
                class="flex items-center justify-center w-11 h-11 rounded-xl border-2 border-[#2a2a2a] bg-[#121212] hover:bg-[#1a1a1a] hover:border-[#383838] transition-all duration-150"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              <!-- LinkedIn -->
              <a
                href={personal.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="LinkedIn"
                class="flex items-center justify-center w-11 h-11 rounded-xl border-2 border-[#2a2a2a] bg-[#121212] hover:bg-[#1a1a1a] hover:border-[#383838] transition-all duration-150"
              >
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
              <!-- Resume -->
              <a
                href="/assets/Shakoor-Shaik-Resume.pdf"
                download
                aria-label="Download resume"
                class="flex items-center gap-2 h-11 px-4 rounded-xl border-2 border-[#2a2a2a] bg-[#121212] text-[15px] font-semibold text-[#d0d0d0] hover:bg-[#1a1a1a] hover:border-[#383838] hover:text-white transition-all duration-150"
              >
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                Resume
              </a>
            </div>
          </div>

          <!-- Right: terminal — wider + taller than before; vertically centered beside copy on md+ -->
          <div class="w-full md:w-[clamp(340px,36vw,420px)] lg:w-[clamp(400px,32vw,480px)] xl:w-[520px] shrink-0 animate-fade-up delay-2 h-[420px] sm:h-[460px] md:h-[490px] lg:h-[540px] xl:h-[580px]">
            <HeroTerminal client:only="react" />
          </div>

        </div>
      </section>

      <div class="main-below-hero">
        <!-- ═══════════════════════════════════════════
             PROJECTS (React island)
        ════════════════════════════════════════════ -->
        <div class="animate-fade-up delay-3">
          <Projects client:load />
        </div>

        <!-- ═══════════════════════════════════════════
             TECH STACK
        ════════════════════════════════════════════ -->
        <section id="stack" class="animate-fade-up delay-5 py-24 md:py-28 border-t border-[var(--color-border)]">
          <h2 class="text-2xl md:text-3xl xl:text-[2.125rem] font-semibold mb-4 tracking-tight text-[var(--color-foreground)]">Core Technologies</h2>
          <p class="text-[17px] md:text-[19px] xl:text-[20px] text-[var(--color-muted)] mb-12 md:mb-14 max-w-none leading-relaxed">
            Languages and frameworks I rely on to build production-ready applications.
          </p>
          <div class="flex flex-wrap gap-3.5 md:gap-4">
            {techStack.map((item) => (
              <span class="group flex items-center gap-3 text-[16px] md:text-[17px] px-5 py-3.5 md:px-6 md:py-4 rounded-xl border-2 border-[#1f1f1f] bg-[#0f0f0f] text-[var(--color-muted)] hover:text-foreground hover:border-[#363636] hover:bg-[#141414] transition-all duration-150 cursor-default tracking-wide font-medium">
                <img
                  src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${item.icon}/${item.icon}-original.svg`}
                  alt=""
                  width="20"
                  height="20"
                  class="w-5 h-5 md:w-[22px] md:h-[22px] object-contain grayscale brightness-150 opacity-70 group-hover:grayscale-0 group-hover:brightness-100 group-hover:opacity-100 transition-all duration-200"
                  onerror="this.style.display='none'"
                />
                {item.name}
              </span>
            ))}
          </div>
        </section>

        <!-- ═══════════════════════════════════════════
             TOOLS & SERVICES
        ════════════════════════════════════════════ -->
        <section id="tools" class="animate-fade-up delay-6 py-24 md:py-28 border-t border-[var(--color-border)]">
          <h2 class="text-2xl md:text-3xl xl:text-[2.125rem] font-semibold mb-4 tracking-tight text-[var(--color-foreground)]">Workflow &amp; Tooling</h2>
          <p class="text-[17px] md:text-[19px] xl:text-[20px] text-[var(--color-muted)] mb-12 md:mb-14 max-w-none leading-relaxed">
            Platforms and tools I use day to day for development, design, and delivery.
          </p>
          <div class="flex flex-wrap gap-3.5 md:gap-4">
            {tools.map((tool) => (
              <span class="group flex items-center gap-3 text-[16px] md:text-[17px] px-5 py-3.5 md:px-6 md:py-4 rounded-xl border-2 border-[#1f1f1f] bg-[#0f0f0f] text-[var(--color-muted)] hover:text-foreground hover:border-[#363636] hover:bg-[#141414] transition-all duration-150 cursor-default tracking-wide font-medium">
                <img
                  src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${tool.icon}/${tool.icon}-original.svg`}
                  alt=""
                  width="20"
                  height="20"
                  class="w-5 h-5 md:w-[22px] md:h-[22px] object-contain grayscale brightness-150 opacity-70 group-hover:grayscale-0 group-hover:brightness-100 group-hover:opacity-100 transition-all duration-200"
                  onerror="this.style.display='none'"
                />
                {tool.name}
              </span>
            ))}
          </div>
        </section>

        <!-- ═══════════════════════════════════════════
             FOOTER
        ════════════════════════════════════════════ -->
        <footer class="pt-16 md:pt-20 pb-3 border-t border-[var(--color-border)]">
          <p class="text-center text-base md:text-[17px] xl:text-lg text-[var(--color-muted)] leading-relaxed px-4 max-w-[52rem] mx-auto">
            &copy; {new Date().getFullYear()} {personal.name}. This site is
            <a
              href={personal.githubwebsite}
              target="_blank"
              rel="noopener noreferrer"
              class="underline underline-offset-4 hover:text-foreground transition-colors"
            >
              open source</a>.
          </p>
        </footer>
      </div>

    </main>
  </div>
</Layout>
